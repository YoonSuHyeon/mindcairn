# Mindcairn environment variables — all optional. Works with defaults:
#   embeddings = local Ollama (bge-m3), LLM = Claude Code CLI (OAuth, no key needed)

# ── Embeddings ──────────────────────────────────────────
# ollama (default) | openai
EMBEDDING_PROVIDER=ollama
# Model defaults: ollama→bge-m3 (1024d), openai→text-embedding-3-small (1536d)
# MINDCAIRN_EMBED_MODEL=bge-m3
# MINDCAIRN_EMBED_DIM=1024
# Required when EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# For an OpenAI-compatible proxy / alternative endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── LLM (needed for Discovery/Strategy/Eval) ────────────
# Auto-detect: API if ANTHROPIC_API_KEY is set, otherwise the claude CLI (OAuth).
# ANTHROPIC_API_KEY=sk-ant-...
# Force a path: claude-cli | api
# MINDCAIRN_LLM=claude-cli
# If the claude CLI lives somewhere unusual
# MINDCAIRN_CLAUDE_BIN=claude
# For the API path (optional): proxy endpoint / response max_tokens
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# MINDCAIRN_API_MAX_TOKENS=8192
# Per-call LLM timeout (ms) — kills a hung claude CLI / API call so indexing can't wedge (default 120000)
# MINDCAIRN_LLM_TIMEOUT_MS=120000

# ── Enricher (LLM chunk labeling at index time — improves search quality) ──
# claude-cli | api | off | auto (default — off if detection fails)
ENRICHER=auto

# ── Models (optional) ───────────────────────────────────
# MINDCAIRN_MODEL_LARGE=claude-opus-4-7
# MINDCAIRN_MODEL_FAST=claude-haiku-4-5-20251001

# ── Infra locations (optional) ──────────────────────────
# MINDCAIRN_QDRANT_HOST=http://localhost:6333
# MINDCAIRN_OLLAMA_HOST=http://localhost:11434

# ── MCP server (optional) ───────────────────────────────
# MINDCAIRN_MCP_PORT=8765
# MINDCAIRN_MCP_HOST=0.0.0.0
# MINDCAIRN_READONLY=1                # expose search tools only (team-shared instance)
# Write-tool IP whitelist (comma-separated). localhost ALWAYS allowed. If unset, remote writes are
# blocked — only localhost may write. Set this to permit specific remote (VPN/Tailscale) IPs.
# MINDCAIRN_WRITE_IPS=100.x.y.z
# Trust the reverse proxy's X-Forwarded-For so req.ip is the real client (needed for the whitelist to
# work behind a proxy). Values: loopback | a specific IP | a hop count. DO NOT set if not behind a
# proxy — it would let clients spoof their IP via headers and bypass MINDCAIRN_WRITE_IPS.
# MINDCAIRN_TRUST_PROXY=loopback

# ── Output location (optional) ──────────────────────────
# MINDCAIRN_OUTPUT_DIR=.mindcairn
